<Window x:Class="DataBinding.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataBinding"
        mc:Ignorable="d"
        Title="Data Binding" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>

        <!-- Name -->
        <Label Grid.Row="1"
           Grid.Column="1"
           Margin="2"
           Content="Name"/>

        <TextBox Text="{Binding Path=Name, Mode=OneWayToSource}"
             Grid.Row="1"
             Grid.Column="3"
             Margin="2"/>

        <!-- Age -->
        <Label Grid.Row="2"
           Grid.Column="1"
           Margin="2"
           Content="Age"/>

        <TextBox Text="{Binding Path=Age, Mode=OneWayToSource}"
             Grid.Row="2"
             Grid.Column="3"
             Margin="2"/>

        <!-- Address -->
        <Label Grid.Row="3"
           Grid.Column="1"
           Margin="2"
           Content="Address"/>

        <TextBox Text="{Binding Path=Address, Mode=OneWayToSource}"
             Grid.Row="3"
             Grid.Column="3"
             Margin="2"/>

        <!-- City -->
        <Label Grid.Row="4"
           Grid.Column="1"
           Margin="2"
           Content="City"/>

        <TextBox Text="{Binding Path=City, Mode=OneWayToSource}"
             Grid.Row="4"
             Grid.Column="3"
             Margin="2"/>

        <!-- Buttons -->
        <Button Grid.Column="1"
        Grid.Row="6"
        Margin="2"
        Height="35"
        Content="Add Person"
        Click="AddPerson_Click"/>

        <Button Grid.Column="3"
        Grid.Row="6"
        Margin="2"
        Height="35"
        Content="Show Info"
        Click="Button_Click"/>

        <!-- First ListBox -->
        <ListBox SelectionMode="Multiple" 
                 x:Name="ListBoxPeople"
             Grid.Row="8"
             Grid.Column="1"
             Margin="2">
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Age}"/>
                        <TextBlock Text="{Binding Address}"/>
                        <TextBlock Text="{Binding City}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Second ListBox -->
        <ListBox x:Name="ListBoxNames"
             Grid.Row="8"
             Grid.Column="3"
             Margin="2"/>

    </Grid>
</Window>
