<Window x:Class="Login.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Login"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Border Width="350"
                Height="300"
                Background="White"
                CornerRadius="12"
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Login"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,25"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Username - Hint: admin"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="UsernameBox"
                         Height="35"
                         FontSize="14"
                         Padding="10,5"
                         Margin="0,0,0,15"
                         TextChanged="InputChanged"/>

                <TextBlock Text="Password - Hint: 1234"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="35"
                             FontSize="14"
                             Padding="10,5"
                             Margin="0,0,0,25"
                             PasswordChanged="InputChanged"/>

                <Button x:Name="LoginButton" 
                        
                        Content="Login"
                        Height="35"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="LoginButton_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
