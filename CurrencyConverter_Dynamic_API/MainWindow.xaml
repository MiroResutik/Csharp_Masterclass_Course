<Window x:Class="CurrencyConverter_Dynamic_API.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CurrencyConverter_Dynamic_API"
        mc:Ignorable="d"
        Title="Currency Converter Dynamic using JSON API Call"
        MinHeight="550"
        MinWidth="850"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">

        <!-- Responsive rows -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                Text="Currency Converter"
                FontSize="32"
                FontWeight="Bold"
                Foreground="#ec2075"
                HorizontalAlignment="Center"
                Margin="0,10"/>

        <!-- Converted Currency -->
        <StackPanel Grid.Row="1"
                 Margin="0,10"
                 HorizontalAlignment="Center">

            <TextBlock Text="Converted Currency"
                    FontSize="22"
                    HorizontalAlignment="Center"/>

            <Label Name="lblCurrency"
                FontSize="24"
                HorizontalContentAlignment="Center"/>
        </StackPanel>

        <!-- Main Converter Card -->
        <Border Grid.Row="2"
             CornerRadius="12"
             Padding="30"
             Margin="20"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#ec2075" Offset="0.0"/>
                    <GradientStop Color="#f33944" Offset="0.5"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Labels -->
                <Grid Grid.Row="0" Margin="0,0,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                            Text="Enter Amount"
                            Foreground="White"
                            FontSize="20"/>

                    <TextBlock Grid.Column="1"
                            Text="From"
                            Foreground="White"
                            FontSize="20"
                            HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="3"
                            Text="To"
                            Foreground="White"
                            FontSize="20"
                            HorizontalAlignment="Center"/>
                </Grid>

                <!-- Inputs -->
                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Name="txtCurrency"
                          Grid.Column="0"
                          Height="40"
                          Margin="0,0,20,0"
                          FontSize="18"
                          VerticalContentAlignment="Center"
                          PreviewTextInput="NumberValidationTextBox"/>

                    <ComboBox Name="cmbFromCurrency"
                           Grid.Column="1"
                           Height="40"
                           Margin="0,0,20,0"
                           FontSize="18"
                           VerticalContentAlignment="Center"
                           MaxDropDownHeight="300"/>

                    <!-- Arrow -->
                    <Border Grid.Column="2"
                         Background="#ec2075"
                         Width="45"
                         Height="45"
                         CornerRadius="22.5"
                         Margin="0,0,20,0">

                        <Image Height="25"
                            Width="25"
                            Source="/Images/right_arrow.png"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"/>
                    </Border>

                    <ComboBox Name="cmbToCurrency"
                           Grid.Column="3"
                           Height="40"
                           FontSize="18"
                           VerticalContentAlignment="Center"
                           MaxDropDownHeight="300"/>
                </Grid>

            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                 Orientation="Horizontal"
                 HorizontalAlignment="Center"
                 Margin="0,20">

            <Button Name="Convert"
                 Height="45"
                 Width="180"
                 Margin="10"
                 Content="Convert"
                 Click="Convert_Click"
                 Foreground="White"
                 FontSize="20"
                 Style="{StaticResource ButtonRound}">

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#ec2075" Offset="0.0"/>
                        <GradientStop Color="#f33944" Offset="0.5"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

            <Button Name="Clear"
                 Height="45"
                 Width="180"
                 Margin="10"
                 Content="Clear"
                 Click="Clear_Click"
                 Foreground="White"
                 FontSize="20"
                 Style="{StaticResource ButtonRound}">

                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#ec2075" Offset="0.0"/>
                        <GradientStop Color="#f33944" Offset="0.5"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>

        </StackPanel>

        <!-- Bottom Image -->
        <Grid Grid.Row="4">

            <Image Height="150"
                Width="150"
                Source="/Images/money.png"
                Stretch="Uniform"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        </Grid>

    </Grid>
</Window>
